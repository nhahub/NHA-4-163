# Copy to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars — it may contain sensitive defaults.

location    = "eastus"
environment = "staging"
project     = "healthcare"

# Networking
vnet_cidr        = "10.0.0.0/16"
aks_subnet_cidr  = "10.0.1.0/24"
data_subnet_cidr = "10.0.2.0/24"

# AKS
kubernetes_version = "1.29"
node_vm_size       = "Standard_D2s_v5"
node_min_count     = 2
node_max_count     = 6

# Azure Database for PostgreSQL (Flexible Server)
postgres_sku_name       = "B_Standard_B1ms" # use GP_Standard_D2s_v3 for production
postgres_storage_mb     = 32768
postgres_version        = "15"
postgres_database_name  = "healthcare"
postgres_admin_username = "healthcare_app"

# Azure Cache for Redis
redis_capacity = 0       # 0 = 250 MB (Basic/Standard); use 1 for Premium
redis_family   = "C"     # C = Basic/Standard, P = Premium
redis_sku_name = "Basic" # use "Premium" for production (VNet + persistence)

# Azure Container Registry
acr_sku = "Basic" # use "Premium" for geo-replication in production
