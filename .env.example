# ============================================================
# HEALTHCARE HEREDITARY DISEASE PREDICTION SYSTEM
# Local development environment template.
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthcare
POSTGRES_USER=healthcare_app
POSTGRES_PASSWORD=change_me_postgres

# --- Neo4j ---
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j
# URI used by Python driver
NEO4J_URI=bolt://localhost:7687

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET_RAW=healthcare-raw
MINIO_BUCKET_DELTA=healthcare-delta

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=hereditary-disease-prediction
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change_me_minio

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# --- Spark ---
SPARK_MASTER_URL=spark://localhost:7077
# Spark submit packages (used in Makefile spark-submit target)
SPARK_PACKAGES=org.apache.spark:spark-avro_2.12:3.5.1,org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1,io.delta:delta-spark_2.12:3.2.0,org.neo4j:neo4j-connector-apache-spark_2.12:5.3.1_for_spark_3,org.postgresql:postgresql:42.7.3

# --- Application Settings ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change_me_app_secret_32chars_min

# --- API Service ---
API_PORT=8000
MODEL_NAME=hereditary-risk-xgboost
MODEL_STAGE=Staging
# Delta feature store base path (Spark jobs)
DELTA_BASE=s3a://healthcare-delta

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Security / Auth (Phase 7) ---
JWT_SECRET_KEY=change_me_jwt_secret_32_chars_min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_generate_with_fernet_generate_key
ENCRYPTION_KEY_ID=v1
# Optional: previous key for transparent key rotation
# ENCRYPTION_PREVIOUS_KEY=

# --- Feature flags ---
ENABLE_GNN_MODEL=false
ENABLE_SYMPTOM_MODEL=false

# --- XGBoost Hyperparameters (optional overrides) ---
XGB_N_ESTIMATORS=500
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05

# --- Airflow (opt-in, --profile orchestration) ---
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me_generate_with_fernet
AIRFLOW_SECRET_KEY=change_me_airflow_webserver_secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin
AIRFLOW_PORT=8082

# --- Observability (opt-in, --profile observability) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin
